<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - M8 Billiards Match Scoring Utility</title>
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/Site.css" />
</head>
<body>
    <div class="site-shell">
        <header class="site-header">
            <div class="container body-content">
                <div class="site-header-row">
                    <div class="site-brand">M8 Billiards Match Scoring Utility</div>
                    @await Html.PartialAsync("_LoginPartial")
                </div>
                <nav class="site-nav">
                    <a asp-controller="Home" asp-action="Index">Match</a>
                    <a asp-controller="Home" asp-action="ReportView">Report</a>
                    <a asp-controller="Home" asp-action="About">About</a>
                    <a asp-controller="Home" asp-action="Contact">Contact</a>
                </nav>
            </div>
        </header>

        <main class="container body-content site-main">
            @RenderBody()
        </main>

        <footer class="container body-content site-footer">
            <p>&copy; @DateTime.Now.Year - Brian Haas</p>
        </footer>
    </div>
    <script src="~/Scripts/jquery-1.10.2.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
