@model M8ScoreTool.Models.MatchViewModel
@{
    ViewBag.Title = "M8 Match Utility";
}
@using(Html.BeginForm("Edit", "Home")) {
    <h2>Enter Match Ratings and Scores</h2>
    <div class="row">
        <div class="col-xs-6 form-group">
            <h4>Our Team</h4>
            <div class="row">
                <div class="col-xs-3"></div>
                <div class="col-xs-3">
                    Rate
                </div>
                <div class="col-xs-3">Score</div>
                <div class="col-xs-2">Win?</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 1</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set1Rate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set1Score, new { Size = "3" })</div>
                <div class="col-xs-2">@Html.CheckBoxFor(model => model.Set1Win)</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 2</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set2Rate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set2Score, new { Size = "3" })</div>
                <div class="col-xs-2">@Html.CheckBoxFor(model => model.Set2Win)</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 3</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set3Rate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set3Score, new { Size = "3" })</div>
                <div class="col-xs-2">@Html.CheckBoxFor(model => model.Set3Win)</div>

            </div>
            <div class="row">
                <div class="col-xs-3">Set 4</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set4Rate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set4Score, new { Size = "3" })</div>
                <div class="col-xs-2">@Html.CheckBoxFor(model => model.Set4Win)</div>

            </div>
            <div class="row">
                <div class="col-xs-3">Set 5</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set5Rate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set5Score, new { Size = "3" })</div>
                <div class="col-xs-2">@Html.CheckBoxFor(model => model.Set5Win)</div>

            </div>
        </div>

        <div class="col-xs-6 form-group">
            <h4>Opponent</h4>
            <div class="row">
                <div class="col-xs-3"></div>
                <div class="col-xs-3">
                    Rate
                </div>
                <div class="col-xs-3">Score</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 1</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set1ORate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set1OScore, new { Size = "3" })</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 2</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set2ORate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set2OScore, new { Size = "3" })</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 3</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set3ORate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set3OScore, new { Size = "3" })</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 4</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set4ORate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set4OScore, new { Size = "3" })</div>
            </div>
            <div class="row">
                <div class="col-xs-3">Set 5</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set5ORate, new { Size = "3" })</div>
                <div class="col-xs-3">@Html.TextBoxFor(model => model.Set5OScore, new { Size = "3" })</div>
            </div>
        </div>
    </div>
    <div class="row">
        <input type="submit" name="Edit" class="submit" value="Update" />
    </div>
    <div class="row">
        <div class="col-xs-6">
            <div class="row">
                <div class="col-xs-6">
                    Total Rate: @Model.TotalRate

                </div>
                <div class="col-xs-6">
                    Over/Under:  @Model.MatchOverUnder
                </div>
            </div>
        </div>
        <div class="col-xs-6">
            <div class="row">
                <div class="col-xs-6">
                    Total Rate: @Model.TotalORate

                </div>
                <div class="col-xs-6">
                    Over/Under:  @Model.MatchOOverUnder
                </div>
            </div>
        </div>
    </div>
    <br/>
    <div class="row">
        <div class="col-xs-6 text-center">
            Our Team Score<br/>
            <label class="h1">@Model.MatchScore</label>
        </div>
        <div class="col-xs-6 text-center">
            Opponent Team Score<br/>
            <label class="h1">@Model.MatchOScore</label>
        </div>
    </div>
}
*** Notes <br/>
<div class="text-info">
    <ul>
        <li>For players with no rating, enter -1 in their Rate box.</li>
        <li>For a forfeited match, enter -1 in the player score.</li>
    </ul>
   
</div>
@Html.ActionLink("Settings", "Index", "MatchSettings")
&nbsp;&nbsp;
@Html.ActionLink("Report View", "ReportView")
<hr />
<h4>Fifth Set Scenarios</h4>
<div><b>Win the Set</b>
    <table class="table-responsive">
        <tr>
            <td width="150">Score:</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 1)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 2)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 3)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 4)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 5)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 6)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 7)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 8)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 9)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 10)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 11)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 12)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 13)</td>
            <td>@Html.Raw(Model.MatchFiveWin.Rate + 14)</td>
        </tr>
        <tr>
            <td width="150">Must Hold To:</td>
            <td>@Model.MatchFiveWin.RatePlusNone</td>
            <td>@Model.MatchFiveWin.RatePlusOne</td>
            <td>@Model.MatchFiveWin.RatePlusTwo</td>
            <td>@Model.MatchFiveWin.RatePlusThree</td>
            <td>@Model.MatchFiveWin.RatePlusFour</td>
            <td>@Model.MatchFiveWin.RatePlusFive</td>
            <td>@Model.MatchFiveWin.RatePlusSix</td>
            <td>@Model.MatchFiveWin.RatePlusSeven</td>
            <td>@Model.MatchFiveWin.RatePlusEight</td>
            <td>@Model.MatchFiveWin.RatePlusNine</td>
            <td>@Model.MatchFiveWin.RatePlusTen</td>
            <td>@Model.MatchFiveWin.RatePlusEleven</td>
            <td>@Model.MatchFiveWin.RatePlusTwelve</td>
            <td>@Model.MatchFiveWin.RatePlusThirteen</td>
            <td>@Model.MatchFiveWin.RatePlusFourteen</td>
        </tr>
    </table>
</div>
<br/>
<div><b>Lose the Set</b>
     <table class="table-responsive">
         <tr>
             <td width="150">Opp. Score</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 1)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 2)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 3)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 4)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 5)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 6)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 7)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 8)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 9)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 10)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 11)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 12)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 13)</td>
             <td>@Html.Raw(Model.MatchFiveLose.Rate + 14)</td>
         </tr>
         <tr>
             <td width="150">Must Score</td>
             <td>@Model.MatchFiveLose.RatePlusNone</td>
             <td>@Model.MatchFiveLose.RatePlusOne</td>
             <td>@Model.MatchFiveLose.RatePlusTwo</td>
             <td>@Model.MatchFiveLose.RatePlusThree</td>
             <td>@Model.MatchFiveLose.RatePlusFour</td>
             <td>@Model.MatchFiveLose.RatePlusFive</td>
             <td>@Model.MatchFiveLose.RatePlusSix</td>
             <td>@Model.MatchFiveLose.RatePlusSeven</td>
             <td>@Model.MatchFiveLose.RatePlusEight</td>
             <td>@Model.MatchFiveLose.RatePlusNine</td>
             <td>@Model.MatchFiveLose.RatePlusTen</td>
             <td>@Model.MatchFiveLose.RatePlusEleven</td>
             <td>@Model.MatchFiveLose.RatePlusTwelve</td>
             <td>@Model.MatchFiveLose.RatePlusThirteen</td>
             <td>@Model.MatchFiveLose.RatePlusFourteen</td>
         </tr>
     </table>
</div>
